# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Primary connection string and database name (used by Motor / database.py)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lumora
DATABASE_NAME=lumora

# ─── IBM Watsonx / Granite ────────────────────────────────────────────────────
# Fill in to enable real IBM Granite calls; leave blank to use mock mode.
WATSONX_API_KEY=your_ibm_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_DEFAULT_MODEL=ibm/granite-13b-instruct-v2

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change_me_to_a_random_secret_key_32_chars_min
APP_CORS_ORIGINS=http://localhost:3000

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_another_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ─── AI feature flags ─────────────────────────────────────────────────────────
AI_ENABLED=true
# Return stub responses when WATSONX_API_KEY is not configured
AI_MOCK_WHEN_UNCONFIGURED=true

# ─── Pagination ───────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AI=20/minute
